{
  "manifest_version": 2,
  "version": "1.0.0",
  "name": "discord_adapter",
  "description": "Discord platform adapter for MaiBot with duplex gateway support for Guild, DM, Thread, reaction, and voice routing.",
  "author": {
    "name": "litroenade",
    "url": "https://github.com/2829798842"
  },
  "license": "GPL-v3.0",
  "urls": {
    "repository": "https://github.com/litroenade/MaiBot-Discord-Adapter",
    "homepage": "https://github.com/litroenade/MaiBot-Discord-Adapter",
    "documentation": "https://github.com/litroenade/MaiBot-Discord-Adapter",
    "issues": "https://github.com/litroenade/MaiBot-Discord-Adapter/issues"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.0.0"
  },
  "sdk": {
    "min_version": "2.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [
    {
      "type": "python_package",
      "name": "discord.py",
      "version_spec": ">=2.3.0"
    },
    {
      "type": "python_package",
      "name": "discord-ext-voice-recv",
      "version_spec": ">=0.4.1a139"
    },
    {
      "type": "python_package",
      "name": "PyNaCl",
      "version_spec": ">=1.5.0"
    }
  ],
  "capabilities": [],
  "i18n": {
    "default_locale": "zh-CN",
    "supported_locales": [
      "zh-CN",
      "en-US"
    ]
  },
  "id": "maibot-discord-adapter"
}
